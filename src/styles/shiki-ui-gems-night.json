{
  "$schema": "vscode://schemas/color-theme",
  "name": "UI Gems Night",
  "type": "dark",
  "colors": {
    "editor.background": "#0f1219",
    "editor.foreground": "#c9d1d9",
    "editorLineNumber.foreground": "#3b4252",
    "editorLineNumber.activeForeground": "#818cf8",
    "editor.selectionBackground": "#6366f133",
    "editor.lineHighlightBackground": "#818cf80a"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#545c7a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.quoted.single",
        "string.quoted.double"
      ],
      "settings": {
        "foreground": "#a8d8a8"
      }
    },
    {
      "name": "Template string expressions",
      "scope": [
        "string.template punctuation.definition.template-expression",
        "string.template meta.template.expression"
      ],
      "settings": {
        "foreground": "#c9d1d9"
      }
    },
    {
      "name": "Numbers & Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#f0b271"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c4a1f5"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#88c9f7"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7eb8f0"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function variable.parameter"
      ],
      "settings": {
        "foreground": "#f0b271",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#c9d1d9"
      }
    },
    {
      "name": "Types / Classes / Interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#7ec9c9"
      }
    },
    {
      "name": "Interfaces & Type parameters",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#7ec9c9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#7a8199"
      }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f07e7e"
      }
    },
    {
      "name": "Attributes (HTML/JSX)",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c4a1f5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#88c9f7"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#a8d8a8"
      }
    },
    {
      "name": "CSS Functions",
      "scope": [
        "support.function.css",
        "support.function.misc.css",
        "support.function.transform.css"
      ],
      "settings": {
        "foreground": "#7eb8f0"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#f0b271"
      }
    },
    {
      "name": "CSS Pseudo-classes & Pseudo-elements",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#c4a1f5"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit.css",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#f07e7e"
      }
    },
    {
      "name": "CSS @-rules",
      "scope": [
        "keyword.control.at-rule.css",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#c4a1f5"
      }
    },
    {
      "name": "CSS Custom Properties (variables)",
      "scope": [
        "variable.css",
        "variable.argument.css",
        "support.type.custom-property.css"
      ],
      "settings": {
        "foreground": "#7ec9c9"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7eb8f0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#f0b271",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#c4a1f5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json support.type.property-name"
      ],
      "settings": {
        "foreground": "#88c9f7"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#f07e7e"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function"
      ],
      "settings": {
        "foreground": "#7ec9c9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import/Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#c4a1f5"
      }
    },
    {
      "name": "this/self",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#f07e7e",
        "fontStyle": "italic"
      }
    }
  ]
}
