---
import TableOfContents from "@/components/TableOfContents.astro";
import type { CollectionEntry } from "astro:content";
import Base from "./Base.astro";

interface Props {
  post: CollectionEntry<"posts">;
  headings: { depth: number; slug: string; text: string }[];
}

const { post, headings } = Astro.props;
const { title, description, date, updated, tags, series, issue } = post.data;

// Auto-calculate reading time from body word count
const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(words / 200));

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(date);

const formattedUpdated = updated
  ? new Intl.DateTimeFormat("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(updated)
  : null;

const filteredHeadings = headings.filter((h) => h.depth <= 3);
---

<Base title={title} description={description}>
  <div class="post-layout">
    <article class="article">
      <!-- Header -->
      <header class="article-header">
        <div class="article-meta">
          <span class="article-series">{series}{issue ? ` #${issue}` : ""}</span>
          <span class="article-sep">·</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="article-sep">·</span>
          <span>{readingTime} min read</span>
        </div>
        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>

      <!-- Footer -->
      <footer class="article-footer">
        {formattedUpdated && (
          <p class="article-updated">Last updated: {formattedUpdated}</p>
        )}
        <div class="article-cta">
          <p>
            This article is part of <strong>UI Gems</strong> — a weekly series
            exploring advanced CSS techniques and experimental web specifications.
            Interactive demos are exclusive to this site.
          </p>
          <div class="display-row flex-wrap gap-md">
            <a href="https://medium.com/@projectluis" target="_blank" rel="noopener" class="follow-link">
              Read on Medium <span class="follow-link-arrow">→</span>
            </a>
            <a href="https://linkedin.com/in/theluistorres" target="_blank" rel="noopener" class="follow-link">
              Follow on LinkedIn <span class="follow-link-arrow">→</span>
            </a>
          </div>
        </div>
      </footer>
    </article>

    <!-- Sidebar TOC -->
    {filteredHeadings.length > 0 && (
      <aside class="post-sidebar">
        <TableOfContents headings={filteredHeadings} />
      </aside>
    )}
  </div>
</Base>

<style>
  :global(pre) {
    margin-inline: calc(-1 * var(--viewport-padding));
  }

  .post-layout {
    /* max-width: var(--content-width); */
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    grid-column-gap: calc(2 * var(--viewport-padding));

    @media (width > 1100px) {
      max-width: none;
      grid-template-columns: 1fr 250px;
    }
  }

  .article { min-width: 0; }

  /* Header */
  .article-header {
    margin-block-end: var(--space-3xl);
  }
  .article-meta {
    font-family: var(--f-ui);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--c-text-muted);
    margin-block-end: var(--space-lg);
  }
  .article-series {
    color: var(--c-accent);
    font-weight: 600;
  }
  .article-sep { color: var(--c-border); }
  .article-title {
    font-family: var(--f-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    color: var(--c-text);
    letter-spacing: -0.025em;
    margin-block-end: var(--space-md);
  }
  .article-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--c-text-secondary);
    max-width: 600px;
  }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-start: var(--space-lg);
  }
  .tag {
    font-family: var(--f-ui);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--c-accent);
    background: var(--c-accent-glow);
    padding: 0.2em 0.65em;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(99, 102, 241, 0.15);
  }

  /* Interactive component wrappers get bleed-out margins */
  :global(.playground-wrapper) {
    margin-inline: calc(-1 * var(--viewport-padding));
  }
 
  /* Footer */
  .article-footer {
    font-family: var(--f-ui);
    margin-block-start: var(--space-3xl);
    padding-block-start: var(--space-xl);
    border-block-start: 1px solid var(--c-border-subtle);
  }
  .article-updated {
    font-size: 0.85rem;
    color: var(--c-text-muted);
    margin-block-end: var(--space-lg);
  }
  .article-cta {
    background: var(--c-bg-raised);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }
  .article-cta p {
    font-size: 0.95rem;
    color: var(--c-text-secondary);
    line-height: 1.6;
    margin-block-end: var(--space-md);
  }

  /* Sidebar */
  .post-sidebar { display: none; }

  @media (width > 1100px) {
    .post-sidebar {
      display: block;
      position: sticky;
      top: 80px;
      align-self: start;
    }
  }
</style>
